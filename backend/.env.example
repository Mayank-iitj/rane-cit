# CNC Intelligence Platform - Backend Environment Configuration
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# Application
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
APP_NAME=CNC Intelligence Platform
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
PORT=8000

# ═══════════════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════════════
DB_TYPE=sqlite
# Or use PostgreSQL in production:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=cnc_user
# DB_PASSWORD=cnc_password
# DB_NAME=cnc_db

# ═══════════════════════════════════════════════════════════════
# Authentication & Security
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_TIME=86400
ALGORITHM=HS256

# Google OAuth 2.0 (Optional - works in demo mode without)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://cnc.mayyanks.app

# ═══════════════════════════════════════════════════════════════
# LLM Providers for Copilot (Multi-Provider Support)
# ═══════════════════════════════════════════════════════════════
# Demo mode works WITHOUT any API keys (fallback responses enabled)
# To enable real LLM responses, add provider API keys:

# Groq (Recommended - Free tier available, fastest)
GROQ_API_KEY=

# OpenAI (GPT-4 quality, premium)
OPENAI_API_KEY=

# Anthropic (Claude-3 reasoning, complex analysis)
ANTHROPIC_API_KEY=

# Azure OpenAI (Enterprise deployment)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Default LLM Provider (groq, openai, anthropic, azure)
COPILOT_DEFAULT_PROVIDER=groq

# Copilot Rate Limiting
COPILOT_RATE_LIMIT_HOURS=100

# ═══════════════════════════════════════════════════════════════
# Redis (Optional - for caching)
# ═══════════════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_EXPIRY=300

# ═══════════════════════════════════════════════════════════════
# Streaming (Optional - Kafka/MQTT)
# ═══════════════════════════════════════════════════════════════
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=cnc-telemetry

MQTT_BROKER=localhost
MQTT_PORT=1883

# ═══════════════════════════════════════════════════════════════
# ML & Features
# ═══════════════════════════════════════════════════════════════
ENABLE_PREDICTIVE_MAINTENANCE=true
ENABLE_COPILOT=true
ENABLE_ENERGY_OPTIMIZATION=true
ENABLE_REAL_TIME_DIAGNOSTICS=true
ALERT_TWILIO_PHONE=+1234567890

# Multi-tenancy
ENABLE_MULTI_TENANT=True
DEFAULT_TENANT_ID=default

# Simulation
ENABLE_SIMULATOR=True
SIMULATOR_MACHINE_COUNT=4
