# CNC Intelligence Platform - Environment Configuration
# Copy this to .env and fill in your values

# Application
APP_NAME=CNC Intelligence Platform
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://cnc_user:cnc_password@localhost:5432/cnc_db

# Database - TimescaleDB (for high-frequency telemetry)
TIMESCALE_URL=postgresql+asyncpg://cnc_user:cnc_password@localhost:5432/cnc_timescale

# Redis (caching and session management)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_EXPIRY=300

# Authentication & Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ISSUER=cnc-platform

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Streaming - Kafka/Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=cnc-telemetry
KAFKA_TOPIC_PREDICTIONS=cnc-predictions
KAFKA_TOPIC_ALERTS=cnc-alerts

# MQTT (fallback for edge devices)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ML Models
MODELS_DIR=models
MODEL_CHECKPOINT_INTERVAL=3600
TRAINING_BATCH_SIZE=32
INFERENCE_BATCH_SIZE=64

# Features
ENABLE_DIGITAL_TWIN=False
ENABLE_COPILOT=False
ENABLE_GCODE_OPTIMIZER=False
ENABLE_ROI_ANALYTICS=True

# Alerting - Email (SendGrid)
ALERT_EMAIL_ENABLED=False
ALERT_EMAIL_FROM=alerts@cnc-platform.example.com

# Alerting - SMS (Twilio)
ALERT_TWILIO_ENABLED=False
ALERT_TWILIO_ACCOUNT_SID=
ALERT_TWILIO_AUTH_TOKEN=
ALERT_TWILIO_PHONE=+1234567890

# Multi-tenancy
ENABLE_MULTI_TENANT=True
DEFAULT_TENANT_ID=default

# Simulation
ENABLE_SIMULATOR=True
SIMULATOR_MACHINE_COUNT=4
