# cnc.mayyanks.app — Environment Configuration
# Copy to .env and fill in production values

# ═══════════════════════════════════════════════════
# Identity
# ═══════════════════════════════════════════════════
APP_NAME=cnc-mayyanks-api
APP_DOMAIN=cnc.mayyanks.app
API_BASE_URL=https://cnc.mayyanks.app/api
DEBUG=false

# ═══════════════════════════════════════════════════
# Database — PostgreSQL + TimescaleDB
# ═══════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://cnc_mayyanks:cnc_secret@localhost:5432/cnc_mayyanks_db
TIMESCALE_URL=postgresql+asyncpg://cnc_mayyanks:cnc_secret@localhost:5432/cnc_mayyanks_db

# ═══════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════
# Authentication
# ═══════════════════════════════════════════════════
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_ISSUER=cnc-mayyanks

# ═══════════════════════════════════════════════════
# Google OAuth 2.0 (PRIMARY AUTH — Google-only login)
# Get credentials at: https://console.cloud.google.com/apis/credentials
# ═══════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
GOOGLE_REDIRECT_URI=https://cnc.mayyanks.app/api/auth/google/callback
# Dev redirect: http://localhost:8000/api/auth/google/callback

# ═══════════════════════════════════════════════════
# Kafka
# ═══════════════════════════════════════════════════
KAFKA_BROKERS=localhost:9092

# ═══════════════════════════════════════════════════
# MQTT
# ═══════════════════════════════════════════════════
MQTT_BROKER=localhost
MQTT_PORT=1883

# ═══════════════════════════════════════════════════
# Internal Service URLs
# ═══════════════════════════════════════════════════
ML_SERVICE_URL=http://cnc-mayyanks-ml-service:8001
REALTIME_SERVICE_URL=http://cnc-mayyanks-realtime:8002
INGESTION_SERVICE_URL=http://cnc-mayyanks-ingestion:8003

# ═══════════════════════════════════════════════════
# Features
# ═══════════════════════════════════════════════════
ENABLE_SIMULATOR=true
ENABLE_DIGITAL_TWIN=true
ENABLE_COPILOT=true
ENABLE_GCODE_OPTIMIZER=true
ENABLE_ENERGY_TRACKING=true
ENABLE_MULTI_TENANT=true
