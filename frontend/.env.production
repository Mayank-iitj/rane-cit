# cnc-mayyanks-frontend — Production Environment Configuration
# These values are used in production builds deployed to cnc.mayyanks.app
# NOTE: Credentials (GOOGLE_CLIENT_SECRET, etc.) should be set via deployment environment,
# not committed to source control. Use GitHub Secrets or deployment platform's env config.

NEXT_PUBLIC_API_URL=https://cnc.mayyanks.app/api
NEXT_PUBLIC_WS_URL=wss://cnc.mayyanks.app/ws
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_SECRET_HERE
GOOGLE_REDIRECT_URI=https://cnc.mayyanks.app/api/auth/google/callback
NEXT_PUBLIC_APP_NAME=cnc.mayyanks.app
