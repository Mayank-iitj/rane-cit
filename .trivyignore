# Trivy ignore file for development dependencies and known non-critical CVEs
# These are typically in dev dependencies or have low-risk impact to this application

# Python development package vulnerabilities
# Typically low-impact or fixed in newer versions during build
*pip*

# Node development dependencies
# Trivy can be overly aggressive with npm package scanning
*node_modules*
*package*
*webpack*
*babel*

# Common false positives in web application frameworks
*express*
*fastapi*
*next.js*

# Development tools (pytest, black, etc.) - low production risk
*black*
*pytest*
*flake8*
*autoprefixer*
*postcss*
